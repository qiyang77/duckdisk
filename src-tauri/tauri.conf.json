{
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://localhost:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "DuckDisk",
    "version": "0.5.1"
  },
  "tauri": {
    "allowlist": {
      "all": true,
      "fs": {
        "all": false,
        "copyFile": false,
        "createDir": false,
        "exists": false,
        "readDir": false,
        "readFile": false,
        "removeDir": true,
        "removeFile": true,
        "renameFile": false,
        "scope": [
          "**"
        ],
        "writeFile": false
      }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "Copyright (C) 2026 Qi Yang",
      "deb": {
        "depends": []
      },
      "externalBin": [
        "bin/pdu"
      ],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/256x256.png",
        "icons/icon.icns"
      ],
      "identifier": "com.duckdisk.dev",
      "longDescription": "",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": "-"
      },
      "resources": [],
      "shortDescription": "",
      "targets": [
        "app",
        "dmg"
      ]
    },
    "security": {
      "csp": null
    },
    "updater": {
      "active": false,
      "endpoints": [],
      "dialog": false,
      "pubkey": ""
    },
    "macOSPrivateApi": true,
    "windows": [
      {
        "fullscreen": false,
        "height": 600,
        "resizable": true,
        "title": "DuckDisk",
        "width": 1100,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ]
  }
}
